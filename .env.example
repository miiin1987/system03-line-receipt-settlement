# LINE Messaging API
LINE_CHANNEL_SECRET=your_line_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here

# Google Sheets
# スプレッドシートのURL内のIDを貼る
# 例: https://docs.google.com/spreadsheets/d/XXXX/edit → XXXXの部分
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here

# Google サービスアカウントのJSONファイルの内容を1行に変換して貼る
# 変換方法: python -c "import json; print(json.dumps(json.load(open('service_account.json'))))"
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Google Maps Platform API キー
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# OpenAI API キー
OPENAI_API_KEY=sk-your_openai_api_key_here

# 志水さんのLINEユーザーID（支払者自動判定に使用）
# 取得方法: LINEにテキスト送信後、サーバーログに表示されるuser_idを確認
SHIMIZU_USER_ID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cronジョブ認証シークレット（任意の文字列）
CRON_SECRET=your_random_secret_here
